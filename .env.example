# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in what you have.
# Everything is optional — with nothing set, the dashboard runs
# on realistic DEMO data so you can see it immediately.
# ─────────────────────────────────────────────────────────────

# ---- Editing goals from the dashboard ----
# Password required to save goal changes via the "Edit goals" button.
# If unset, editing is disabled (read-only). Set it to enable the editor.
GOALS_EDIT_PASSWORD=

# Shared store for saved goals. On Vercel, add the Vercel KV (or Upstash)
# integration and it injects these automatically. Locally you can leave them
# blank — edits fall back to data/store.json.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ---- RevenueCat (money) ----
# v2 SECRET API key:  RevenueCat dashboard > Project settings > API keys
REVENUECAT_V2_API_KEY=
# Project id: the long id in your RevenueCat dashboard URL
REVENUECAT_PROJECT_ID=
# Lifetime revenue earned BEFORE you connected this dashboard.
# The overview API only reports the trailing 28 days, so this baseline is
# added to it to show "generated so far". Set to 0 to show 28-day revenue only.
REVENUE_BASELINE=0

# ---- TikTok (views) ----
# Which view source to use: snapshot | html | demo | scraper | official
TIKTOK_PROVIDER=snapshot

# The videos you've posted (your content "script"), comma or newline separated.
# Used by the collector script and the html/scraper/official providers.
TIKTOK_VIDEO_URLS=https://www.tiktok.com/@yourhandle/video/0000000000000000000

# --- Option A: yt-dlp snapshot (no API, no key) [recommended] ---
# A GitHub Action runs yt-dlp on a schedule and publishes a JSON snapshot to a
# `data` branch; the app reads it from this raw URL (no redeploy needed).
# Format: https://raw.githubusercontent.com/<you>/<repo>/data/tiktok-views.json
TIKTOK_SNAPSHOT_URL=
# If TIKTOK_SNAPSHOT_URL is empty, the app falls back to data/tiktok-views.json,
# which you can generate locally with:  npm run collect:tiktok

# --- Option B: direct HTML scrape (no API, but TikTok WAF blocks servers) ---
# Reads playCount from the page HTML. Usually blocked from datacenter IPs.

# --- Option C: third-party scraper (paid, survives datacenter IPs) ---
TIKTOK_SCRAPER_BASE_URL=
TIKTOK_SCRAPER_HOST=
TIKTOK_SCRAPER_API_KEY=

# --- Option D: official TikTok for Developers API (needs app + approval) ---
TIKTOK_ACCESS_TOKEN=
